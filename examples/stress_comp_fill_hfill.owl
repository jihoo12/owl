-- stress_comp_fill_hfill.owl — comp, fill, hfill operations
--
-- Exercises: basic comp/fill/hfill with trivial and non-trivial faces,
-- endpoint reductions, and nesting.

inductive Nat where
  | zero : Nat
  | suc : Nat -> Nat

-- ═══════════════════════════════════════════════════════════════════════════
-- 1. comp with trivial face (always true) — reduces to tube @ 1
-- ═══════════════════════════════════════════════════════════════════════════

def comp_trivial : Nat :=
  comp Nat 1 (<i> suc zero) (suc zero)

-- ═══════════════════════════════════════════════════════════════════════════
-- 2. comp with bottom face (never true) — reduces to base
-- ═══════════════════════════════════════════════════════════════════════════

def comp_bot : Nat :=
  comp Nat 0 (<i> zero) zero

-- ═══════════════════════════════════════════════════════════════════════════
-- 3. comp with meet face (1 /\ 1 = 1, always true)
-- ═══════════════════════════════════════════════════════════════════════════

def comp_meet : Nat :=
  comp Nat (1 /\ 1) (<i> suc zero) (suc zero)

-- ═══════════════════════════════════════════════════════════════════════════
-- 4. fill with trivial face — @ i1 reduces to tube
-- ═══════════════════════════════════════════════════════════════════════════

def fill_trivial_at1 : Nat :=
  fill Nat 1 (<i> suc zero) (suc zero) @ i1

-- ═══════════════════════════════════════════════════════════════════════════
-- 5. fill with bottom face — @ i1 reduces to base
-- ═══════════════════════════════════════════════════════════════════════════

def fill_bot_at1 : Nat :=
  fill Nat 0 (<i> zero) zero @ i1

-- ═══════════════════════════════════════════════════════════════════════════
-- 6. fill @ i0 reduces to base
-- ═══════════════════════════════════════════════════════════════════════════

def fill_at_zero : Nat :=
  fill Nat 1 (<i> suc zero) (suc zero) @ i0

-- ═══════════════════════════════════════════════════════════════════════════
-- 7. fill @ i1 reduces to comp
-- ═══════════════════════════════════════════════════════════════════════════

def fill_at_one : Nat :=
  fill Nat 1 (<i> suc zero) (suc zero) @ i1

-- ═══════════════════════════════════════════════════════════════════════════
-- 8. hfill with trivial face — @ i1 reduces to tube
-- ═══════════════════════════════════════════════════════════════════════════

def hfill_trivial_at1 : Nat :=
  hfill Nat 1 (<i> suc zero) (suc zero) @ i1

-- ═══════════════════════════════════════════════════════════════════════════
-- 9. hfill with bottom face — @ i1 reduces to base
-- ═══════════════════════════════════════════════════════════════════════════

def hfill_bot_at1 : Nat :=
  hfill Nat 0 (<i> zero) zero @ i1

-- ═══════════════════════════════════════════════════════════════════════════
-- 10. hfill @ i0 reduces to base
-- ═══════════════════════════════════════════════════════════════════════════

def hfill_at_zero : Nat :=
  hfill Nat 1 (<i> suc zero) (suc zero) @ i0

-- ═══════════════════════════════════════════════════════════════════════════
-- 11. hfill @ i1 reduces to hcomp
-- ═══════════════════════════════════════════════════════════════════════════

def hfill_at_one : Nat :=
  hfill Nat 1 (<i> suc zero) (suc zero) @ i1

-- ═══════════════════════════════════════════════════════════════════════════
-- 12. comp in a function
-- ═══════════════════════════════════════════════════════════════════════════

def comp_in_fn : Nat -> Nat :=
  fun n => comp Nat 1 (<i> n) n

-- ═══════════════════════════════════════════════════════════════════════════
-- 13. fill in a function
-- ═══════════════════════════════════════════════════════════════════════════

def fill_in_fn : Nat -> Nat :=
  fun n => fill Nat 1 (<i> n) n @ i1

-- ═══════════════════════════════════════════════════════════════════════════
-- 14. hfill in a function
-- ═══════════════════════════════════════════════════════════════════════════

def hfill_in_fn : Nat -> Nat :=
  fun n => hfill Nat 1 (<i> n) n @ i1

-- ═══════════════════════════════════════════════════════════════════════════
-- 15. Nested comp
-- ═══════════════════════════════════════════════════════════════════════════

def nested_comp : Nat :=
  comp Nat 1
    (<i> comp Nat 1 (<i> suc zero) (suc zero))
    (suc (suc zero))

-- ═══════════════════════════════════════════════════════════════════════════
-- 16. comp returning a pair (Sigma decomposition)
-- ═══════════════════════════════════════════════════════════════════════════

def comp_pair : Nat * Nat :=
  comp (Nat * Nat) 1 (<i> (zero , zero)) (zero , zero)

-- ═══════════════════════════════════════════════════════════════════════════
-- 17. transport over comp
-- ═══════════════════════════════════════════════════════════════════════════

def transport_comp : Nat :=
  transport (<i> Nat)
    (comp Nat 1 (<i> suc zero) (suc zero))

-- ═══════════════════════════════════════════════════════════════════════════
-- 18. comp with join face
-- ═══════════════════════════════════════════════════════════════════════════

def comp_join : Nat :=
  comp Nat (0 \/ 0) (<i> zero) zero

-- ═══════════════════════════════════════════════════════════════════════════
-- 19. fill with meet face
-- ═══════════════════════════════════════════════════════════════════════════

def fill_meet : Nat :=
  fill Nat (1 /\ 1) (<i> suc zero) (suc zero) @ i1

-- ═══════════════════════════════════════════════════════════════════════════
-- 20. hfill with meet face
-- ═══════════════════════════════════════════════════════════════════════════

def hfill_meet : Nat :=
  hfill Nat (1 /\ 1) (<i> suc zero) (suc zero) @ i1

-- ═══════════════════════════════════════════════════════════════════════════
-- 21. fill in nested function
-- ═══════════════════════════════════════════════════════════════════════════

def fill_nested_fn : Nat -> Nat -> Nat :=
  fun m n => fill Nat 1 (<i> n) n @ i1

-- ═══════════════════════════════════════════════════════════════════════════
-- 22. hfill in nested function
-- ═══════════════════════════════════════════════════════════════════════════

def hfill_nested_fn : Nat -> Nat -> Nat :=
  fun m n => hfill Nat 1 (<i> n) n @ i1

-- ═══════════════════════════════════════════════════════════════════════════
-- 23. comp in nested function
-- ═══════════════════════════════════════════════════════════════════════════

def comp_nested_fn : Nat -> Nat -> Nat :=
  fun m n => comp Nat 1 (<i> n) n

-- ═══════════════════════════════════════════════════════════════════════════
-- 24. fill path applied at interval variable
-- ═══════════════════════════════════════════════════════════════════════════

def fill_apply_interval : Path Nat (suc zero) (suc zero) :=
  <i> fill Nat 1 (<i> suc zero) (suc zero) @ i

-- ═══════════════════════════════════════════════════════════════════════════
-- 25. hfill path applied at interval variable
-- ═══════════════════════════════════════════════════════════════════════════

def hfill_apply_interval : Path Nat (suc zero) (suc zero) :=
  <i> hfill Nat 1 (<i> suc zero) (suc zero) @ i

-- ═══════════════════════════════════════════════════════════════════════════
-- 26. comp, fill, hfill all agree on the same computation
-- ═══════════════════════════════════════════════════════════════════════════

def comp_val : Nat := comp Nat 1 (<i> suc zero) (suc zero)
def fill_val : Nat := fill Nat 1 (<i> suc zero) (suc zero) @ i1
def hfill_val : Nat := hfill Nat 1 (<i> suc zero) (suc zero) @ i1

-- ═══════════════════════════════════════════════════════════════════════════
-- Main entry point
-- ═══════════════════════════════════════════════════════════════════════════

def main : Nat := comp_val
