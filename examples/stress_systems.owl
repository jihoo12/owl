-- stress_systems.owl — General system tests for hcomp
--
-- Exercises: multi-face systems with the => syntax.

inductive Nat where
  | zero : Nat
  | suc : Nat -> Nat

-- ═══════════════════════════════════════════════════════════════════════════
-- 1. Single-face: tube matches base
-- ═══════════════════════════════════════════════════════════════════════════

def t1 : Nat :=
  hcomp Nat [i1 => <i> suc zero] (suc zero)

-- ═══════════════════════════════════════════════════════════════════════════
-- 2. Multi-face: both tubes match base
-- ═══════════════════════════════════════════════════════════════════════════

def t2 : Nat :=
  hcomp Nat [i0 => <i> suc zero, i1 => <i> suc zero] (suc zero)

-- ═══════════════════════════════════════════════════════════════════════════
-- 3. Multi-face: both tubes are constant zero
-- ═══════════════════════════════════════════════════════════════════════════

def t3 : Nat :=
  hcomp Nat [i0 => <i> zero, i1 => <i> zero] zero

-- ═══════════════════════════════════════════════════════════════════════════
-- 4. Single-face: constant tube matches base
-- ═══════════════════════════════════════════════════════════════════════════

def t4 : Nat :=
  hcomp Nat [i1 => <i> zero] zero

-- ═══════════════════════════════════════════════════════════════════════════
-- 5. Three faces: all tubes match base
-- ═══════════════════════════════════════════════════════════════════════════

def t5 : Nat :=
  hcomp Nat [i0 => <i> suc zero, i1 => <i> suc zero] (suc zero)

-- ═══════════════════════════════════════════════════════════════════════════
-- 6. Multi-face with non-trivial faces: meet face (1 /\ 1 = 1)
-- ═══════════════════════════════════════════════════════════════════════════

def t6 : Nat :=
  hcomp Nat [1 /\ 1 => <i> suc zero] (suc zero)

-- ═══════════════════════════════════════════════════════════════════════════
-- 7. Multi-face with join face (0 \/ 0 = 0, bottom face)
-- ═══════════════════════════════════════════════════════════════════════════

def t7 : Nat :=
  hcomp Nat [0 \/ 0 => <i> zero] zero

def main : Nat := zero
